---
import projectsFile from '../data/projects.json';
import { augmentProjectsWithImages, type ProjectEntry } from '../lib/fetchGitHub';
import { withBase } from '../lib/assetPath';

interface Props {
  featuredOnly?: boolean;
}
const { featuredOnly = false } = Astro.props;

const allProjectsData = await augmentProjectsWithImages(projectsFile.items as ProjectEntry[]);
const displayProjects = featuredOnly
  ? allProjectsData.filter((p) => p.sliderImage)
  : allProjectsData;

import { icons } from '../lib/icons';

const categoryFilters = [...new Set(allProjectsData.map((p) => p.category))].map((cat) => ({
  label: cat.replace(/\b\w/g, (c) => c.toUpperCase()),
  value: cat,
}));

const filters = [
  { label: 'Featured', value: 'featured' },
  { label: 'All', value: 'all' },
  ...categoryFilters,
];

const projectsJson = JSON.stringify(
  allProjectsData.map((p) => ({
    ...p,
    sliderImage:   p.sliderImage   ? withBase(p.sliderImage)   : p.sliderImage,
    backgroundImage: p.backgroundImage ? withBase(p.backgroundImage) : p.backgroundImage,
  }))
);
---

<section id="projects" class="py-24 bg-slate-900/30" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">My work</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Featured Projects</h2>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-10 reveal" style="transition-delay:0.1s;">
      {
        filters.map((f) => (
          <button
            class="filter-btn"
            data-filter={f.value}
            aria-pressed={f.value === 'featured' ? 'true' : 'false'}
          >
            {f.label}
            <span class="filter-count" data-count={f.value} />
          </button>
        ))
      }
    </div>

    <div
      id="projects-grid"
      class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
    >
      {
        displayProjects.map((project, i) => (
          <div
            class={`project-card reveal${project.backgroundImage ? ' has-bg' : ''}`}
            data-category={project.category}
            data-featured={(project as any).featured ? 'true' : 'false'}
            data-index={i}
            style={`transition-delay: ${(i % 3) * 0.07}s;`}
            role="button"
            tabindex="0"
            aria-label={`Open details for ${project.title}`}
          >
            {(project as any).colorIcon && (
              <div class="float-icon-wrap" aria-hidden="true">
                <img
                  src={withBase(
                    (project as any).colorIcon.includes(':')
                      ? `/images/icons/${(project as any).colorIcon.replace(':', '/')}.svg`
                      : (project as any).colorIcon
                  )}
                  alt=""
                  class="float-icon"
                  loading="lazy"
                  width="44"
                  height="44"
                />
              </div>
            )}

            <div class={`project-card-inner${project.backgroundImage ? ' has-bg-img' : ''}`}>
              {project.backgroundImage && (
                <div class="card-bg-img" aria-hidden="true">
                  <img
                    src={withBase(project.backgroundImage!)}
                    alt=""
                    loading="lazy"
                    width="600"
                    height="400"
                  />
                </div>
              )}

              <div class="card-glow" aria-hidden="true" />

              <div class="p-5 flex flex-col flex-1 relative z-10">
                <div class="flex items-start justify-between gap-3 mb-3">
                  <p class="text-xs font-bold text-highlight uppercase tracking-widest leading-tight">
                    {project.company}
                  </p>
                </div>

                <h3 class="project-title text-lg font-bold mb-2 leading-snug">{project.title}</h3>

                <p class="card-desc text-slate-400 text-sm leading-relaxed flex-1 mb-4">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>

              <div class="project-footer relative z-10">
                <div class="footer-shimmer" aria-hidden="true" />
                <span class="category-badge">{project.category}</span>
                {project.icon && icons[project.icon] && (
                  <div class="card-icon shrink-0">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="1.5"
                      stroke="currentColor"
                      class="w-5 h-5"
                      set:html={icons[project.icon]}
                    />
                  </div>
                )}
                <span class="view-hint">
                  <span class="view-hint-text">Click for link to project</span>
                  <svg
                    class="view-hint-arrow"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    />
                  </svg>
                </span>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <p id="projects-empty" class="hidden text-center text-slate-600 text-sm mt-12">
      No projects in this category yet.
    </p>
  </div>
</section>

<div
  id="project-modal"
  class="modal-backdrop"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  hidden
>
  <div class="modal-container" id="modal-container">
    <button class="modal-close" id="modal-close" aria-label="Close">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-5 h-5">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>

    <div class="modal-hero" id="modal-hero">
      <div class="modal-hero-overlay"></div>
      <div class="modal-hero-content">
        <div id="modal-category-badge" class="modal-cat-badge"></div>
        <h2 id="modal-title" class="modal-heading"></h2>
        <p id="modal-company" class="modal-company"></p>
      </div>
    </div>

    <div class="modal-body">
      <p id="modal-description" class="modal-description"></p>
      <div id="modal-tags" class="modal-tags"></div>

      <div class="modal-cta-wrap">
        <a id="modal-link" href="#" target="_blank" rel="noopener" class="modal-cta-link">
          <img
            src={withBase('/images/assets/icon--link.png')}
            alt=""
            width={18}
            height={18}
            class="modal-link-icon"
          />
          <span id="modal-link-text">View Project</span>
          <svg class="modal-cta-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
            ></path>
          </svg>
        </a>
        <p id="modal-no-link" class="modal-no-link hidden">Private / No public link available.</p>
      </div>
    </div>
  </div>
</div>

<!-- define:vars injects the server-rendered JSON blob as a JS variable in this inline script.
     is:inline is required alongside define:vars; without it Astro would bundle the script
     and the injected variable would not be in scope. -->
<script is:inline define:vars={{ projectsJson }}>
  const projects = JSON.parse(projectsJson);

  document.querySelectorAll('#projects .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.05 }
    );
    io.observe(el);
  });

  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.project-card[data-category]');
  const empty = document.getElementById('projects-empty');
  let active = null;

  document.querySelectorAll('.filter-count').forEach((el) => {
    const cat = el.dataset.count;
    let n;
    if (cat === 'all') n = cards.length;
    else if (cat === 'featured') n = [...cards].filter((c) => c.dataset.featured === 'true').length;
    else n = [...cards].filter((c) => c.dataset.category === cat).length;
    el.textContent = `${n}`;
  });

  function applyFilter(filter) {
    if (filter === active) return;
    active = filter;
    filterBtns.forEach((b) => {
      const on = b.dataset.filter === filter;
      b.classList.toggle('filter-active', on);
      b.setAttribute('aria-pressed', String(on));
    });
    let visible = 0;
    cards.forEach((card) => {
      const matches =
        filter === 'all' ||
        (filter === 'featured' && card.dataset.featured === 'true') ||
        card.dataset.category === filter;
      card.classList.remove('pf-enter');
      if (!matches) {
        card.classList.add('pf-hidden');
      } else {
        card.classList.remove('pf-hidden');
        card.style.setProperty('--enter-delay', `${visible * 0.05}s`);
        // Force a reflow so the browser registers the class removal before re-adding pf-enter.
        // Without this, the CSS animation does not restart when re-showing an already-visible card.
        void card.offsetWidth;
        card.classList.add('pf-enter');
        visible++;
      }
    });
    if (empty) empty.classList.toggle('hidden', visible > 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter));
  });

  applyFilter('featured');
  document.querySelector('[data-filter="featured"]')?.classList.add('filter-active');

  const modal = document.getElementById('project-modal');
  const container = document.getElementById('modal-container');
  const closeBtn = document.getElementById('modal-close');
  const modalHero = document.getElementById('modal-hero');
  const modalCat = document.getElementById('modal-category-badge');
  const modalTitle = document.getElementById('modal-title');
  const modalCo = document.getElementById('modal-company');
  const modalDesc = document.getElementById('modal-description');
  const modalTags = document.getElementById('modal-tags');
  const modalLink = document.getElementById('modal-link');
  const modalLinkTx = document.getElementById('modal-link-text');
  const modalNoLink = document.getElementById('modal-no-link');

  function openModal(idx) {
    const p = projects[idx];
    if (!p) return;

    const img = p.backgroundImage || null;
    if (img) {
      modalHero.style.backgroundImage = `url('${img}')`;
      modalHero.style.display = '';
    } else {
      modalHero.style.backgroundImage = '';
      modalHero.style.display = 'none';
    }

    modalCat.textContent = p.category;
    modalTitle.textContent = p.title;
    modalCo.textContent = p.company;
    modalDesc.textContent = p.description;

    modalTags.innerHTML = '';
    for (const t of p.tags) {
      const span = document.createElement('span');
      span.className = 'tag';
      span.textContent = t;
      modalTags.appendChild(span);
    }

    if (p.link) {
      modalLink.href = p.link;
      if (p.link.includes('github.com')) modalLinkTx.textContent = 'View on GitHub';
      else if (p.link.includes('gitlab')) modalLinkTx.textContent = 'View on GitLab';
      else if (p.link.includes('blog')) modalLinkTx.textContent = 'Read the Post';
      else modalLinkTx.textContent = 'View Project';
      modalLink.classList.remove('hidden');
      modalNoLink.classList.add('hidden');
    } else {
      modalLink.classList.add('hidden');
      modalNoLink.classList.remove('hidden');
    }

    // The `hidden` attribute (not a CSS class) is used here because the modal-backdrop rule
    // sets `display:none !important` on `[hidden]`, which gives correct AT (screen reader) semantics.
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden'; // prevent page scroll while modal is open
    void container.offsetWidth;
    modal.classList.add('modal-open');
    closeBtn.focus();
  }

  function closeModal() {
    modal.classList.remove('modal-open');
    modal.classList.add('modal-closing');
    setTimeout(() => {
      modal.setAttribute('hidden', '');
      modal.classList.remove('modal-closing');
      document.body.style.overflow = '';
    }, 280);
  }

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      openModal(parseInt(card.dataset.index, 10));
    });
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openModal(parseInt(card.dataset.index, 10));
      }
    });
  });

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) closeModal();
  });
</script>

<style is:global>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    background: var(--bg-section);
    border: 1px solid var(--border);
    cursor: pointer;
    transition:
      color 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .filter-btn:hover {
    color: var(--text-muted);
    background: var(--bg-card);
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }
  .filter-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .filter-btn.filter-active {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.4);
  }
  .filter-count {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-dimmer);
    background: var(--border);
    border-radius: 9999px;
    padding: 0 0.35rem;
    min-width: 1.1rem;
    text-align: center;
    transition:
      color 0.2s ease,
      background 0.2s ease;
  }
  .filter-btn.filter-active .filter-count {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.15);
  }

  .project-card {
    transition: opacity 0.2s ease;
    position: relative;
    cursor: pointer;
  }
  .project-card:focus-visible .project-card-inner {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .project-card.pf-hidden {
    display: none;
  }
  .project-card.pf-enter {
    animation: card-enter 0.4s cubic-bezier(0.22, 1, 0.36, 1) var(--enter-delay, 0s) both;
  }
  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .float-icon-wrap {
    position: absolute;
    top: -14px;
    right: 16px;
    z-index: 20;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--bg-card-solid);
    border: 1px solid var(--border);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7px;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .project-card:hover .float-icon-wrap {
    transform: translateY(-4px) scale(1.1);
    border-color: var(--border-hover);
    box-shadow:
      0 8px 28px rgba(0, 0, 0, 0.35),
      0 0 18px rgba(99, 102, 241, 0.15);
  }
  .float-icon {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .float-icon-mdi {
    filter: invert(1) brightness(0.85);
  }

  .category-badge {
    font-size: 0.56rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    background: rgba(99, 102, 241, 0.05);
    border: 1px solid rgba(99, 102, 241, 0.12);
    opacity: 0.7;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    position: relative;
    z-index: 1;
    white-space: nowrap;
    transition:
      color 0.3s ease,
      background 0.3s ease,
      border-color 0.3s ease,
      opacity 0.3s ease;
  }
  .project-card:hover .category-badge {
    color: var(--text-muted);
    background: rgba(99, 102, 241, 0.1);
    border-color: rgba(99, 102, 241, 0.3);
    opacity: 1;
  }
  .project-card.has-bg .category-badge {
    color: rgba(226, 232, 240, 0.65);
  }

  .card-bg-img {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: inherit;
  }
  .card-bg-img::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(155deg, rgba(4, 8, 22, 0.38) 0%, rgba(4, 8, 22, 0.62) 100%);
    transition: background 0.55s ease;
  }
  .project-card:hover .card-bg-img::after {
    background: linear-gradient(155deg, rgba(4, 8, 22, 0.26) 0%, rgba(4, 8, 22, 0.5) 100%);
  }
  .card-bg-img img {
    position: absolute;
    inset: -10%;
    width: 120%;
    height: 120%;
    object-fit: cover;
    object-position: center;
    filter: blur(24px) saturate(2.1) brightness(0.44) grayscale(0.25);
    transition: filter 0.55s ease;
  }
  .project-card:hover .card-bg-img img {
    filter: blur(18px) saturate(2.5) brightness(0.56) grayscale(0.25);
  }

  .project-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--bg-card);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow: hidden;
    transition:
      transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      border-color 0.35s ease,
      box-shadow 0.35s ease;
  }
  .project-card-inner.has-bg-img {
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
  .project-card:hover .project-card-inner {
    transform: translateY(-5px);
    border-color: rgba(99, 102, 241, 0.4);
    box-shadow:
      0 20px 52px rgba(0, 0, 0, 0.38),
      0 0 0 1px rgba(99, 102, 241, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .project-title {
    color: var(--text);
    transition: color 0.35s ease;
  }
  .project-card:not(.has-bg):hover .project-title {
    color: var(--accent);
  }
  .project-card.has-bg .project-title {
    color: #e2e8f0;
  }
  .project-card.has-bg:hover .project-title {
    color: var(--accent);
  }

  .project-card.has-bg .card-desc {
    color: rgba(203, 213, 225, 0.82);
  }

  .card-glow {
    display: none;
  }

  .project-footer {
    overflow: hidden;
    border-top: 1px solid var(--border);
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    background: rgba(0, 0, 0, 0.1);
    gap: 0.75rem;
    transition:
      border-top-color 0.35s ease,
      background 0.35s ease;
  }
  .project-card:hover .project-footer {
    border-top-color: rgba(99, 102, 241, 0.22);
    background: rgba(99, 102, 241, 0.06);
  }
  .project-card.has-bg .project-footer {
    background: rgba(0, 0, 0, 0.32);
    border-top-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  .project-card.has-bg:hover .project-footer {
    background: rgba(99, 102, 241, 0.22);
    border-top-color: rgba(99, 102, 241, 0.35);
  }
  .footer-shimmer {
    display: none;
  }

  .card-icon {
    color: rgba(99, 102, 241, 0.45);
    transition: color 0.35s ease;
  }
  .project-card:hover .view-hint svg {
    color: rgba(99, 102, 241, 0.85);
    transform: rotate(-8deg) scale(1.15);
  }

  .view-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-dimmer);
    margin-left: auto;
    position: relative;
    z-index: 1;
    transition:
      color 0.3s ease,
      gap 0.35s ease;
    user-select: none;
  }
  .view-hint-arrow {
    width: 0.8rem;
    height: 0.8rem;
    flex-shrink: 0;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.3s ease;
    opacity: 0.5;
  }
  .project-card:hover .view-hint {
    color: var(--accent);
    gap: 0.6rem;
  }
  .project-card:hover .view-hint-arrow {
    transform: translate(3px, -3px);
    opacity: 1;
  }
  .project-card.has-bg .view-hint {
    color: rgba(148, 163, 184, 0.55);
  }

  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 5vh 1rem 2rem;
    background: rgba(2, 6, 23, 0.82);
    overflow-y: auto;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .modal-backdrop[hidden] {
    display: none !important;
  }
  .modal-backdrop.modal-open {
    opacity: 1;
    pointer-events: auto;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .modal-backdrop.modal-closing {
    opacity: 0;
    pointer-events: none;
  }

  .modal-container {
    position: relative;
    width: 100%;
    max-width: 640px;
    background: var(--bg-overlay);
    border: 1px solid var(--border);
    border-radius: 1.25rem;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(99, 102, 241, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transform: translateY(28px) scale(0.97);
    transition:
      transform 0.32s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.28s ease;
    opacity: 0;
  }
  .modal-open .modal-container {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
  .modal-closing .modal-container {
    transform: translateY(16px) scale(0.98);
