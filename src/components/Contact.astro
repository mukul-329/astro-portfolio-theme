---
import personalData from '../data/personal.json';
import siteData from '../data/site.json';
import { getSocialLinks } from '../lib/socialLinks';

const socialLinks = getSocialLinks(personalData as unknown as Record<string, string | string[]>);
---

<section
  id="contact"
  class="py-24"
  style="background: var(--bg-section); position: relative; z-index: 5; scroll-margin-top: 80px;"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12 reveal">
        <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
          Contact me
        </p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Let's talk.</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-4 reveal" style="transition-delay: 0.1s;">
          {personalData.email && (
          <div class="card">
            <div class="flex items-center gap-4">
              <div
                class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold text-sm">Email</h3>
                <a
                  href={`mailto:${personalData.email}`}
                  class="text-slate-400 text-sm hover:text-accent transition-colors"
                >
                  {personalData.email}
                </a>
              </div>
            </div>
          </div>
          )}

          {
            personalData.phone && (
              <div class="card">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0">
                    <svg
                      class="w-5 h-5 text-accent"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                      />
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-white font-semibold text-sm">Phone</h3>
                    <a
                      href={personalData.phoneTel}
                      class="text-slate-400 text-sm hover:text-accent transition-colors"
                    >
                      {personalData.phone}
                    </a>
                  </div>
                </div>
              </div>
            )
          }

          <div class="card">
            <div class="flex items-center gap-4">
              <div
                class="w-10 h-10 rounded-lg bg-accent/10 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-accent"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold text-sm">Location</h3>
                <p class="text-slate-400 text-sm">{personalData.location}</p>
              </div>
            </div>
          </div>

          {
            socialLinks.length > 0 && (
              <div class="card">
                <h3 class="text-white font-semibold text-sm mb-4">Where Else You Can Find Me:</h3>
                <div class="flex flex-wrap gap-4">
                  {socialLinks.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="contact-social-link"
                      aria-label={link.label}
                    >
                      <iconify-icon icon={link.icon} width="20" height="20" aria-hidden="true" />
                    </a>
                  ))}
                </div>
              </div>
            )
          }
        </div>

        <div class="card reveal" style="transition-delay: 0.2s;">
          <form id="contact-form" class="space-y-4" novalidate>
            <input type="hidden" name="access_key" value={siteData.web3formsKey} />
            <!-- Honeypot: hidden from users but bots fill it in.
                 Web3Forms rejects any submission where this field is checked. -->
            <input
              type="checkbox"
              name="botcheck"
              class="hidden"
              style="display:none;"
              aria-hidden="true"
            />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label
                  for="name"
                  class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                  >Name</label
                >
                <input
                  type="text"
                  id="name"
                  name="name"
                  autocomplete="name"
                  required
                  class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                  placeholder="My name…"
                />
              </div>
              <div>
                <label
                  for="email"
                  class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                  >Email</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  autocomplete="email"
                  inputmode="email"
                  spellcheck="false"
                  required
                  class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                  placeholder="you@example.com"
                />
              </div>
            </div>

            <div>
              <label
                for="subject"
                class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                >Subject</label
              >
              <input
                type="text"
                id="subject"
                name="subject"
                autocomplete="off"
                required
                class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors placeholder:text-slate-600"
                placeholder="Let us know…"
              />
            </div>

            <div>
              <label
                for="message"
                class="block text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2"
                >Message</label
              >
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full bg-slate-900/60 border border-slate-700/60 rounded-lg px-4 py-3 text-white text-sm focus:outline-hidden focus-visible:border-accent focus-visible:ring-1 focus-visible:ring-accent/50 transition-colors resize-none placeholder:text-slate-600"
                placeholder="What would you like to tell us?"></textarea>
            </div>

            <div aria-live="polite" aria-atomic="true" id="form-status" class="sr-only"></div>
            <button type="submit" class="btn-primary w-full flex items-center justify-center gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="send-icon w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"
                ></path>
                <path d="m21.854 2.147-10.94 10.939"></path>
              </svg>
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('#contact .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLElement | null;
  const button = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  // Stash the button's original inner HTML before mutating it to "Sending…".
  // Restored in the finally block so the button always returns to its original state,
  // including any icon SVG, regardless of whether the request succeeded or failed.
  const BUTTON_HTML = button?.innerHTML ?? 'Send Message';

  function setStatus(msg: string, isError: boolean) {
    if (!status) return;
    status.textContent = msg;
    status.className = isError ? 'mt-3 text-sm text-red-400' : 'mt-3 text-sm text-green-400';
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (button) {
      button.disabled = true;
      button.textContent = 'Sending…';
    }
    setStatus('', false);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form!),
      });
      const data = (await res.json()) as { success?: boolean; message?: string };
      if (res.ok) {
        setStatus("Message sent! I'll be in touch soon.", false);
        form!.reset();
      } else {
        setStatus(data.message ?? 'Something went wrong. Please try again.', true);
      }
    } catch {
      setStatus('Network error. Check your connection and try again.', true);
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = BUTTON_HTML;
      }
    }
  });
</script>

<style>
  .contact-social-link {
    color: #64748b;
    display: inline-flex;
    align-items: center;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    border-radius: 0.125rem;
  }
  .contact-social-link:hover {
    color: var(--accent);
    transform: translateY(-2px);
  }
  .contact-social-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  :global([data-theme='light']) .text-white {
    color: black;
  }
  :global([data-theme='light']) #contact textarea,
  :global([data-theme='light']) #contact input {
    background: white !important;
  }

  #contact button.btn-primary .send-icon {
    transition:
      transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 200ms ease;
    will-change: transform;
    transform: translateX(3rem) translateY(1.25rem) scale(2);
    opacity: 1;
  }
  #contact button.btn-primary:hover .send-icon {
    transform: translateX(8rem) translateY(-3rem) scale(1);
    opacity: 0;
    transition-duration: 100ms;
  }
  #contact button.btn-primary:active .send-icon {
    transform: translateX(8rem) translateY(-3rem) scale(1);
    opacity: 0;
    transition-duration: 100ms;
  }
  #contact .card button.btn-primary {
    padding: 0.175rem 2rem 1.25rem;
  }

  @media (min-width: 368px) and (max-width: 1023px) {
    #contact button.btn-primary .send-icon {
      transform: translateX(1rem) translateY(1.25rem) scale(2);
    }
  }

  @media (max-width: 367px) {
    #contact button.btn-primary .send-icon {
      transform: translateX(-1.25rem) translateY(1.25rem) scale(2);
    }
  }
</style>
